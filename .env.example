# ---- Site URL (used for canonical, Open Graph, sitemap, robots) ----
# Set this to your live domain once you have one.
NEXT_PUBLIC_SITE_URL=https://ravi-d-dave-co.vercel.app

# ---- Contact form email delivery ----
# Set ONE of the two options below so the contact form can deliver to your inbox.

# Option A (recommended, easiest): Web3Forms — free, no domain needed.
#   1. Go to https://web3forms.com, enter caravidave33@gmail.com, get your Access Key.
#   2. Paste it here / add it as a Vercel Environment Variable.
WEB3FORMS_ACCESS_KEY=

# Option B: Resend (https://resend.com) — free tier. If set, it is used instead of Web3Forms.
